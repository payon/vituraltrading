// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// 사용자 관련 모델
// ============================================

/// 사용자 정보
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?  // 비밀번호 (해시됨)
  
  // 사용자 설정
  language  String   @default("ko")       // 언어 설정 (ko, en, etc.)
  theme     String   @default("system")   // 테마 (light, dark, system)
  investmentStyle String?                 // 투자성향 (conservative, moderate, aggressive)
  
  // 모의투자 계좌
  initialBalance   Float  @default(10000000)  // 초기자금 (1000만원)
  currentBalance   Float  @default(10000000)  // 현재잔고
  
  // 이메일 인증
  emailVerified    DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  settings          Settings?
  learningProgress  LearningProgress[]
  portfolios        Portfolio[]
  transactions      Transaction[]
  diaries           InvestmentDiary[]
  accounts          Account[]
  sessions          Session[]
  watchlist         Watchlist[]
}

/// NextAuth Account (OAuth 등)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// NextAuth Session
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

/// 이메일 인증 토큰
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  
  createdAt DateTime @default(now())
  
  @@unique([identifier, token])
}

/// 사용자 설정
model Settings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 알림 설정
  pushNotification Boolean @default(true)
  emailNotification Boolean @default(false)
  priceAlertEnabled Boolean @default(true)
  
  // 표시 설정
  currencyUnit     String  @default("KRW")    // 통화 단위
  chartStyle       String  @default("candle") // 차트 스타일 (candle, line)
  darkModeEnabled  Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// 학습 관련 모델
// ============================================

/// 학습 카테고리
enum LearningCategory {
  STOCK_BASICS      // 주식기초
  CHART_ANALYSIS    // 차트분석
  INVESTMENT_STRATEGY // 투자전략
  RISK_MANAGEMENT   // 위험관리
}

/// 학습 콘텐츠
model LearningContent {
  id          String           @id @default(cuid())
  category    LearningCategory
  title       String
  description String?
  content     String           // Markdown 내용
  example     String?          // 예시
  
  // 메타 정보
  difficulty  Int              @default(1)    // 난이도 (1-5)
  order       Int              @default(0)    // 순서
  isActive    Boolean          @default(true) // 활성화 여부
  
  // 추정 학습 시간 (분)
  estimatedMinutes Int?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  quizzes    Quiz[]
  progresses LearningProgress[]
  
  @@index([category])
  @@index([order])
}

/// 퀴즈
model Quiz {
  id                String          @id @default(cuid())
  contentId         String
  content           LearningContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  question          String          // 문제
  options           String          // 선택지 (JSON 배열)
  correctAnswer     Int             // 정답 인덱스 (0-based)
  explanation       String?         // 해설
  
  // 메타 정보
  order             Int             @default(0)
  isActive          Boolean         @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([contentId])
}

/// 학습 진도
model LearningProgress {
  id          String   @id @default(cuid())
  userId      String
  contentId   String
  
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     LearningContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  // 진도 상태
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?
  
  // 퀴즈 결과
  quizScore     Float?          // 퀴즈 점수 (0-100)
  quizAttempts  Int     @default(0) // 퀴즈 시도 횟수
  
  // 학습 시간 (분)
  timeSpent     Int     @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
}

// ============================================
// 모의투자 관련 모델
// ============================================

/// 종목 종류
enum AssetType {
  STOCK   // 주식
  COIN    // 코인
}

/// 모의투자 포트폴리오
model Portfolio {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 종목 정보
  assetType   AssetType
  symbol      String              // 종목코드 (예: 005930, BTC)
  name        String              // 종목명 (예: 삼성전자, 비트코인)
  
  // 매입 정보
  buyPrice    Float               // 매입가 (평균 단가)
  quantity    Float               // 수량
  totalCost   Float               // 총 매입 금액
  
  // 현재 정보
  currentPrice Float?             // 현재가
  evaluatedAmount Float?          // 평가금액
  profitRate    Float?            // 수익률 (%)
  profitAmount  Float?            // 수익금액
  
  // 거래일
  boughtAt    DateTime  @default(now())
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, symbol, assetType])
  @@index([userId])
  @@index([symbol])
}

/// 주문 유형
enum OrderType {
  MARKET    // 시장가
  LIMIT     // 지정가
}

/// 거래 유형
enum TransactionType {
  BUY       // 매수
  SELL      // 매도
}

/// 거래 상태
enum TransactionStatus {
  PENDING   // 대기
  COMPLETED // 완료
  CANCELLED // 취소
}

/// 거래 내역
model Transaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 종목 정보
  assetType   AssetType
  symbol      String
  name        String
  
  // 거래 정보
  transactionType TransactionType
  orderType       OrderType      @default(MARKET)
  
  price       Float             // 주문 가격
  quantity    Float             // 주문 수량
  totalAmount Float             // 총 주문 금액
  
  // 수수료
  fee         Float             @default(0)
  
  // 상태
  status      TransactionStatus @default(PENDING)
  
  // 거래일
  tradedAt    DateTime          @default(now())
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
  @@index([symbol])
  @@index([tradedAt])
}

// ============================================
// 투자 일기 & 감정 분석 모델
// ============================================

/// 투자 일기
model InvestmentDiary {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 일기 내용
  date        DateTime             // 거래 날짜
  content     String?              // 일기 내용
  tradeSummary String?             // 매매내역 요약
  tradeReason  String?             // 매매이유
  
  // 감정 기록
  emotionState String?             // 감정상태 (JSON: 주요 감정)
  emotionScore Int?                // 감정 강도 (1-10)
  emotions    String?              // 감정 리스트 (JSON: [{type, intensity}])
  
  // 자가 평가
  selfRating  Int?                 // 자가평가 (1-5)
  
  // AI 분석 결과
  aiAnalysis    String?            // AI 분석결과 (JSON)
  improvements  String?            // 개선점
  
  // 투자 성향 분석
  investmentStyle String?          // 분석된 투자 성향
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  emotionAnalyses EmotionAnalysis[]
  
  @@index([userId])
  @@index([date])
}

/// 감정 유형
enum EmotionType {
  GREED       // 욕심
  FEAR        // 공포
  HOPE        // 희망
  ANXIETY     // 불안
  CONFIDENCE  // 자신감
}

/// 감정 분석
model EmotionAnalysis {
  id          String       @id @default(cuid())
  diaryId     String
  diary       InvestmentDiary @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  
  // 감정 분석 결과
  emotionType EmotionType
  intensity   Int          // 강도 (1-10)
  
  // AI 코멘트
  aiComment   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([diaryId])
}

// ============================================
// 시스템 설정 모델
// ============================================

/// 시스템 설정 (관리자용)
model SystemSettings {
  id        String   @id @default(cuid())
  
  // 데이터 소스 설정
  stockDataSource   String  @default("yahoo")  // yahoo, kis, naver, mock
  coinDataSource    String  @default("upbit")  // upbit, mock
  
  // KIS API 설정 (암호화 저장)
  kisAppKey         String?
  kisAppSecret      String?
  kisAccountNo      String?
  kisEnabled        Boolean @default(false)
  
  // Upbit API 설정
  upbitAccessKey    String?
  upbitSecretKey    String?
  upbitEnabled      Boolean @default(false)
  
  // 시스템 설정
  maintenanceMode   Boolean @default(false)
  allowRegistration Boolean @default(true)
  defaultInitialBalance Float @default(10000000)  // 기본 초기 자금
  
  // 마지막 업데이트
  lastPriceUpdate   DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// 시세 데이터 모델
// ============================================

/// 시세 데이터
model PriceHistory {
  id          String    @id @default(cuid())
  
  // 종목 정보
  assetType   AssetType
  symbol      String
  
  // OHLCV 데이터
  openPrice   Float     // 시가
  highPrice   Float     // 고가
  lowPrice    Float     // 저가
  closePrice  Float     // 종가
  volume      Float     // 거래량
  
  // 날짜/시간
  timestamp   DateTime  // 날짜시간
  interval    String    @default("1d") // 간격 (1m, 5m, 15m, 1h, 4h, 1d, 1w)
  
  createdAt DateTime @default(now())
  
  @@unique([symbol, assetType, timestamp, interval])
  @@index([symbol, assetType])
  @@index([timestamp])
}

// ============================================
// 관심종목 모델
// ============================================

/// 관심종목 (즐겨찾기)
model Watchlist {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 종목 정보
  assetType   AssetType
  symbol      String
  name        String
  
  // 알림 설정
  priceAlertEnabled Boolean @default(false)
  targetPrice       Float?  // 목표가
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, symbol, assetType])
  @@index([userId])
  @@index([symbol])
}
